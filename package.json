{
  "name": "sysmon-mqtt",
  "version": "1.0.0",
  "description": "System sensor monitor that publishes metrics via MQTT",
  "author": {
    "name": "kekkooo86",
    "email": "xtxmotard@gmail.com"
  },
  "homepage": "https://github.com/kekkooo86/sysmon-mqtt",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux --windows --mac",
    "build:linux": "electron-builder --linux",
    "install:linux-deb": "npm run build:linux && sudo dpkg -i dist/*.deb",
    "start:linux-deb-first-time": "npm run install:linux-deb && sysmon-mqtt --no-sandbox",
    "build:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --windows",
    "build:mac": "electron-builder --mac"
  },
  "private": true,
  "devDependencies": {
    "cross-env": "10.1.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "mqtt": "^5.3.0",
    "systeminformation": "^5.22.0"
  }
}
